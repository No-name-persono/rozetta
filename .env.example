# Flask
SECRET_KEY=change-me
MAX_UPLOAD_MB=64
JOB_TTL_SEC=7200
DELETE_REMOTE_AFTER=1
ASYNC_MAX_WORKERS=4

# Object Storage compatible with Yandex Object Storage/S3.
S3_ENDPOINT=https://storage.yandexcloud.net
S3_REGION=ru-central1
S3_BUCKET=your-bucket
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key

# Yandex SpeechKit STT.
YANDEX_API_KEY=your-yandex-api-key
YANDEX_IAM_TOKEN=
YANDEX_FOLDER_ID=your-folder-id
ASR_API_VERSION=v3
ASR_MODEL=general
ASR_LANGUAGE=ru-RU
ASR_LITERATURE_TEXT=1
ASR_POLL_INTERVAL_SEC=3
ASR_POLL_TIMEOUT_SEC=7200

# YandexGPT.
LLM_API_URL=https://llm.api.cloud.yandex.net/foundationModels/v1/completion
LLM_MODEL_URI=gpt://<folder-id>/yandexgpt/latest
LLM_API_KEY=your-yandex-api-key
LLM_IAM_TOKEN=
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=3500

# Optional speaker soft labels.
SPECTRAL_ENABLED=1
SPECTRAL_N_SPEAKERS=2
SPECTRAL_IVR_CUTOFF_SEC=0
SPECTRAL_CONFIDENCE_CUTOFF=0.55
SPECTRAL_METHOD=windowed
SPECTRAL_WINDOW_SEC=3.5
SPECTRAL_STEP_SEC=0.5
SPECTRAL_TRANSIENT_ENABLED=1
